# Copy to .env (or just export these) and fill in per environment.
# Load with:  set -a; source .env; set +a

# --- Required ---------------------------------------------------------
# Vision One API key bearer token. This scopes the call to the tenant.
V1_BEARER_TOKEN=eyJhbGciOiJ...replace_me...

# --- Tenant / region (change per environment) -------------------------
# Label only; used in output filename/logs (useful when looping tenants).
V1_TENANT_ID=customer-name

# Data region. One of: us, eu, sg, jp, au, in, uae, uk, ca, za
V1_REGION=us
# Or override the base URL completely (takes precedence over V1_REGION):
# V1_BASE_URL=https://api.xdr.trendmicro.com

# --- Selection criteria (change per use case) -------------------------
HOSTNAME_PREFIX=Dev
OFFLINE_HOURS=8

# --- API behaviour (optional) -----------------------------------------
PAGE_SIZE=1000
# Set true to let the API pre-filter to disconnected/off endpoints (faster on
# large estates; the precise 8h test still runs client-side).
USE_CONNECTIVITY_PREFILTER=false
HTTP_TIMEOUT=30
MAX_RETRIES=3

# --- Output (optional) ------------------------------------------------
# OUTPUT_CSV=offline_iws_endpoints.csv
