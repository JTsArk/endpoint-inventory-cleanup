# Copy this file to .env and fill in your values, then lock it down:
#   cp .env.example .env
#   chmod 600 .env
# .env is git-ignored and must never be committed.
#
# run.sh loads these automatically. To load them manually in a shell:
#   set -a; source .env; set +a

# --- Required ---------------------------------------------------------
# Vision One API key bearer token. Needs the "Endpoint Inventory: View"
# permission. Scopes all calls to the tenant that issued the key.
TMV1_TOKEN=replace_me

# Regional API base URL. Must match the region of the tenant that issued
# the token. Defaults to US if unset.
#   US            https://api.xdr.trendmicro.com
#   EU (Germany)  https://api.eu.xdr.trendmicro.com
#   Singapore     https://api.sg.xdr.trendmicro.com
#   Japan         https://api.xdr.trendmicro.co.jp
#   Australia     https://api.au.xdr.trendmicro.com
#   India         https://api.in.xdr.trendmicro.com
#   UAE           https://api.mea.xdr.trendmicro.com
#   UK            https://api.uk.xdr.trendmicro.com
#   Canada        https://api.ca.xdr.trendmicro.com
#   South Africa  https://api.za.xdr.trendmicro.com
TMV1_REGION_URL=https://api.xdr.trendmicro.com
